{
  "expo": {
    "name": "Rep Route",
    "slug": "motionrep-rep",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "bluetoothAlwaysPermission": "Rep Route uses Bluetooth to connect to receipt printers."
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f766e"
    },
    "extra": {
      "apiBaseUrlProd": "https://api.sbdistribution.store",
      "apiBaseUrlDev": "http://192.168.1.20:3001",
      "eas": {
        "projectId": "b2311f82-c175-4db0-a72d-1015e38793e2"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thushanth.motionreprep",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSBluetoothAlwaysUsageDescription": "Rep Route uses Bluetooth to connect to receipt printers."
      }
    },
    "android": {
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f766e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.thushanth.motionreprep"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "thushanth",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b2311f82-c175-4db0-a72d-1015e38793e2"
    }
  }
}
